<view class="container">
  <!-- 出栏日龄信息 -->
  <view class="card">
    <view class="card-title">📅 出栏日龄信息</view>
    
    <view class="form-item">
      <view class="form-label">出栏日龄（天）</view>
      <input class="form-input" type="number" value="{{exitDayAge}}" bindinput="onExitDayAgeInput" placeholder="如：7、14、21...或38" />
    </view>
    <view class="hint">💡 输入出栏日龄后自动从日录入汇总数据（7的倍数为周数据，其他为出栏数据）</view>
  </view>

  <!-- 基础数据 -->
  <view class="card">
    <view class="card-title">📊 基础数据</view>

    <view class="form-row cols2">
      <view>
        <view class="form-label">存栏（只）</view>
        <input class="form-input" type="number" value="{{weekStock}}" bindinput="onStockInput" placeholder="自动计算或手动填写" />
      </view>
      <view>
        <view class="form-label">平均体重（g）*</view>
        <input class="form-input" type="digit" value="{{avgWeight}}" bindinput="onWeightInput" placeholder="每周末称重必填" />
      </view>
    </view>
  </view>

  <!-- 饲料数据 -->
  <view class="card">
    <view class="card-title">🌾 饲料数据</view>

    <view class="form-row cols2">
      <view>
        <view class="form-label">累计上料量（kg）</view>
        <input class="form-input" type="digit" value="{{cumulativeFeed}}" bindinput="onCumulativeFeedInput" placeholder="自动计算或手动填写" />
      </view>
      <view>
        <view class="form-label">库存料量（kg）*</view>
        <input class="form-input" type="digit" value="{{stockFeed}}" bindinput="onStockFeedInput" placeholder="周末料塔剩余必填" />
      </view>
    </view>

    <view class="form-row cols2">
      <view>
        <view class="form-label">累计采食量（kg）</view>
        <input class="form-input" type="digit" value="{{actualFeed}}" bindinput="onActualFeedInput" placeholder="自动计算或手动填写" />
      </view>
      <view>
        <view class="form-label">累计上料金额（元）</view>
        <input class="form-input" type="digit" value="{{cumulativeFeedCost}}" bindinput="onCumulativeFeedCostInput" placeholder="自动计算或手动填写" />
      </view>
    </view>
  </view>

  <!-- 计算指标 -->
  <view class="card">
    <view class="card-title">📈 计算指标</view>

    <view class="form-row cols2">
      <view>
        <view class="form-label">饲料单价（元/吨）</view>
        <input class="form-input" type="digit" value="{{feedPrice}}" bindinput="onFeedPriceInput" placeholder="自动计算或手动填写" />
      </view>
      <view>
        <view class="form-label">累计料比</view>
        <input class="form-input" type="digit" value="{{cumulativeFCR}}" bindinput="onFCRInput" placeholder="自动计算或手动填写" />
      </view>
    </view>

    <view class="form-row cols2">
      <view>
        <view class="form-label">饲料造肉成本（元/斤）</view>
        <input class="form-input" type="digit" value="{{meatCost}}" bindinput="onMeatCostInput" placeholder="自动计算或手动填写" />
      </view>
      <view>
        <view class="form-label">饲料厂家</view>
        <input class="form-input" value="{{feedFactory}}" bindinput="onFeedFactoryInput" placeholder="自动获取或手动填写" />
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="btn-area">
    <button class="btn btn-success" bindtap="saveWeekData" loading="{{saving}}">
      💾 保存本周数据
    </button>
  </view>
</view>
