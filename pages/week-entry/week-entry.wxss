/* 周录入页面样式 */
page {
  background-color: #f5f5f5;
}

.container {
  padding: 12px 14px 20px;
}

/* 表单项 */
.form-item {
  margin-bottom: 12px;
}

.form-label {
  font-size: 13px;
  color: #666;
  margin-bottom: 6px;
}

.form-input {
  height: 36px;
  padding: 0 12px;
  background: #fafafa;
  border: 1px solid #e8e8e8;
  border-radius: 6px;
  font-size: 14px;
}

.form-textarea {
  width: 100%;
  min-height: 80px;
  padding: 10px 12px;
  background: #fafafa;
  border: 1px solid #e8e8e8;
  border-radius: 6px;
  font-size: 14px;
  box-sizing: border-box;
}

/* 两列布局 */
.form-row {
  display: flex;
  gap: 12px;
  margin-bottom: 12px;
}

.form-row > view {
  flex: 1;
}

.form-row .form-label {
  font-size: 12px;
}

.form-row .form-input {
  height: 34px;
}

/* 按钮区域 */
.btn-area {
  margin-top: 20px;
  padding: 0 10px;
}
