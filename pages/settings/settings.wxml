<view class="container">

  <!-- 第一部分：个人信息 -->
  <view class="card">
    <view class="card-title">👤 个人信息</view>
    <!-- 已登录状态 -->
    <view wx:if="{{isLoggedIn}}">
      <view class="user-header">
        <view class="avatar">👤</view>
        <view class="user-info">
          <view class="user-name">{{userInfo.nickName}}</view>
          <view class="user-desc" style="color:#52c41a">微信一键登录</view>
        </view>
      </view>
      <view class="info-row" wx:if="{{phone}}">
        <view class="info-label">📱 已绑定手机号</view>
        <view class="info-value" style="color:#52c41a;font-weight:600">{{phone}}</view>
      </view>
    </view>
    <!-- 未登录状态 -->
    <view wx:if="{{!isLoggedIn}}">
      <view class="user-header">
        <view class="avatar" style="background:#f0f5ff">🐔</view>
        <view class="user-info">
          <view class="user-name">微信用户</view>
          <view class="user-desc" style="color:#999">请先绑定手机号</view>
        </view>
      </view>
      <view class="login-tip">💡 微信已登录，请填写手机号完成绑定</view>
      <view class="form-item">
        <view class="form-label">手机号</view>
        <input class="form-input" type="number" value="{{loginPhone}}" bindinput="onPhoneInput" maxlength="11" placeholder="请输入手机号" />
      </view>
      <button class="btn btn-primary" bindtap="doLogin">✅ 提交绑定</button>
    </view>
  </view>

  <!-- 第二部分：公司信息 -->
  <view class="card">
    <view class="card-title">🏢 公司信息</view>

    <!-- 未绑定状态 -->
    <view wx:if="{{!companyBound}}">
      <view class="info-hint">💡 填好信息后点"确认绑定"，完成公司归属设置</view>

      <view class="form-item">
        <view class="form-label">公司名称</view>
        <input class="form-input" value="{{companyName}}" data-field="companyName" bindinput="checkCompanyInfo" placeholder="如：绿谷农牧" />
      </view>
      <view class="form-item">
        <view class="form-label">所属场区</view>
        <input class="form-input" value="{{companyFarm}}" data-field="companyFarm" bindinput="checkCompanyInfo" placeholder="如：1场" />
      </view>

      <!-- 确认绑定按钮 -->
      <button class="btn btn-primary" bindtap="confirmCompanyBind" style="{{companyBindReady ? '' : 'opacity:0.5;pointer-events:none'}}">🔗 确认绑定</button>

      <view class="no-company-hint">不填则不绑定公司信息</view>
    </view>

    <!-- 已绑定状态 -->
    <view wx:if="{{companyBound}}">
      <view class="bound-success-box">
        <view class="bound-icon">✅</view>
        <view class="bound-title">已绑定公司信息</view>
        <view class="bound-info">🏢 {{companyName}}</view>
        <view class="bound-info">📍 {{companyFarm}} · {{companyHouse}}</view>
      </view>
      <button class="btn btn-danger" bindtap="unbindCompany">🔓 解除绑定</button>
    </view>
  </view>

  <!-- 第三部分：新建批次 -->
  <view class="card">
    <view class="card-title">🐔 {{batchTitle}}</view>

    <!-- 第一行：栋号、品种、类型 -->
    <view style="display:flex;margin-bottom:10px">
      <view style="flex:1;margin-right:6px">
        <view style="font-size:11px;color:#999;text-align:center">栋号</view>
        <input class="form-input" style="text-align:center;font-size:13px" value="{{companyHouse}}" data-field="companyHouse" bindinput="onInput" placeholder="1栋" />
      </view>
      <view style="flex:1;margin-right:6px">
        <view style="font-size:11px;color:#999;text-align:center">品种</view>
        <input class="form-input" style="text-align:center;font-size:13px" value="{{variety}}" data-field="variety" bindinput="onInput" placeholder="科宝+快大" />
      </view>
      <view style="flex:1">
        <view style="font-size:11px;color:#999;text-align:center">类型</view>
        <picker value="{{typeIndex}}" range="{{typeList}}" bindchange="onTypeChange">
          <input class="form-input" style="text-align:center;font-size:13px" value="{{type}}" disabled />
        </picker>
      </view>
    </view>
    <!-- 第二行：入舍日期、入舍数量 -->
    <view style="display:flex;margin-bottom:10px">
      <view style="flex:1;margin-right:6px">
        <view style="font-size:11px;color:#999;text-align:center">入舍日期</view>
        <picker mode="date" value="{{entryDate}}" bindchange="onEntryDateChange">
          <input class="form-input" style="text-align:center;font-size:13px" value="{{entryDate}}" disabled placeholder="选择日期" />
        </picker>
      </view>
      <view style="flex:1">
        <view style="font-size:11px;color:#999;text-align:center">入舍数量（只）</view>
        <input class="form-input" style="text-align:center;font-size:13px" type="number" value="{{qty}}" data-field="qty" bindinput="onInput" placeholder="12800" />
      </view>
    </view>
    <button class="btn btn-success" bindtap="createBatch" style="margin-bottom:14px">✅ 保存</button>
  </view>

</view>
