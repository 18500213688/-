/* 设置页样式 */
page {
  background-color: #f5f5f5;
}

.container {
  padding: 12px 14px 20px;
}

/* 用户信息头部 */
.user-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #e8e8e8;
}

.avatar {
  width: 56px;
  height: 56px;
  background: #e6f4ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 15px;
  font-weight: 600;
}

.user-desc {
  font-size: 11px;
  color: #999;
  margin-top: 2px;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f0f0f0;
}

.info-label {
  font-size: 13px;
  color: #666;
}

.info-value {
  font-size: 13px;
  color: #333;
  font-weight: 500;
}

/* 表单项 */
.form-item {
  margin-bottom: 10px;
}

.form-row {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.form-row > view {
  flex: 1;
}

/* 公司信息 - 未绑定提示 */
.info-hint {
  font-size: 10px;
  color: #999;
  background: #f5f5f5;
  padding: 6px 8px;
  border-radius: 6px;
  margin-bottom: 10px;
}

/* 公司信息 - 绑定成功 */
.bound-success-box {
  background: #f6ffed;
  border: 2px solid #52c41a;
  border-radius: 12px;
  padding: 14px;
  text-align: center;
  margin-bottom: 12px;
}

.bound-icon {
  font-size: 28px;
  margin-bottom: 4px;
}

.bound-title {
  font-size: 13px;
  color: #389e0d;
  font-weight: 700;
  margin-bottom: 6px;
}

.bound-info {
  font-size: 12px;
  color: #333;
  line-height: 1.8;
}

/* 不填则不绑定提示 */
.no-company-hint {
  text-align: center;
  padding: 6px;
  font-size: 11px;
  color: #999;
}

/* 分割线 */
.divider {
  height: 1px;
  background: #e8e8e8;
  margin: 12px 0;
}

/* 分区标题 */
.section-title {
  font-weight: 500;
  margin-bottom: 8px;
}

/* 出栏提示 */
.exit-hint {
  background: #fff7e6;
  border-radius: 8px;
  padding: 8px;
  font-size: 11px;
  color: #ad6800;
  margin-bottom: 10px;
}

/* 已出栏提示 */
.batch-ended-banner {
  background: #d9f7be;
  border: 1px solid #b7eb8f;
  border-radius: 12px;
  padding: 12px;
  text-align: center;
  margin: 10px 0;
}

.batch-ended-banner .ended-title {
  font-size: 14px;
  font-weight: 600;
  color: #52c41a;
  margin-bottom: 4px;
}

.batch-ended-banner .ended-desc {
  font-size: 11px;
  color: #389e0d;
}

/* 登录区域 */
.login-area {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px dashed #e8e8e8;
}

.login-tip {
  font-size: 11px;
  color: #1677ff;
  background: #e8f4ff;
  padding: 8px 12px;
  border-radius: 6px;
  margin-bottom: 12px;
  text-align: center;
}

/* 按钮 */
.btn {
  width: 100%;
  height: 40px;
  border: none;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
}

.btn-primary {
  background: #1677ff;
  color: #fff;
}

.btn-success {
  background: #52c41a;
  color: #fff;
  height: 44px;
  border-radius: 22px;
  font-size: 15px;
}

.btn-danger {
  background: #fff;
  color: #ff4d4f;
  border: 1px solid #ff4d4f;
  border-radius: 20px;
}

/* 当前批次信息展示 */
.current-batch-info {
  background: #f6ffed;
  border: 1px solid #b7eb8f;
  border-radius: 10px;
  padding: 12px 14px;
  margin-bottom: 4px;
}

.cb-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4px 0;
  font-size: 13px;
}

.cb-label {
  color: #666;
}

.cb-value {
  color: #333;
  font-weight: 600;
}
