.bind-card {
  text-align: center;
  padding: 40rpx 30rpx;
}

.bind-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.bind-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.bind-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.bind-info-box {
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.bind-info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.bind-info-item:not(:last-child) {
  border-bottom: 1rpx solid #d9f7be;
}

.bind-info-label {
  font-size: 28rpx;
  color: #666;
}

.bind-info-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #52c41a;
}

.bind-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.bind-btn {
  margin-bottom: 20rpx;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

/* 登录卡片 */
.login-card {
  padding: 50rpx 30rpx;
  text-align: center;
}

.login-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.login-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 微信登录按钮 */
.btn-wechat {
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  margin-bottom: 30rpx;
}

/* 分隔符 */
.login-divider {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e8e8e8;
}

.divider-text {
  font-size: 24rpx;
  color: #999;
  padding: 0 20rpx;
}

/* 用户信息栏 */
.user-info-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.user-detail {
  flex: 1;
  text-align: left;
}

.user-nick {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.user-phone {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.logout-btn {
  font-size: 24rpx;
  color: #ff4d4f;
  background: #fff1f0;
  border: 1rpx solid #ffccc7;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}
